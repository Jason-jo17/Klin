# None of these are required for local dev — BYOK keys are entered in-app
# (Settings) and live only in the browser's IndexedDB.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: lets the Jury's Playwright-driven runs (the "Run Jury" button,
# and `pnpm jury run` in CI) authenticate without a BYOK key saved in a
# browser — Playwright's headless browser has no access to IndexedDB, so a
# server-side fallback key is the only way an automated run can generate.
# Every template's own generate handler already supports this same fallback
# (see templates/*/.env.local.example).
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Optional, only if deploying the public hosted demo (e.g. on Vercel):
# KV_REST_API_URL=              # Vercel KV or Upstash, for IP rate-limiting the proxy route only
# KV_REST_API_TOKEN=
